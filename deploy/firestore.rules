rules_version = '2';

// ===========================================================================
//  Firestore-Sicherheitsregeln für den Communicator (Projekt jupidu-36804)
// ---------------------------------------------------------------------------
//  Frontend (Browser): darf ALLES LESEN, aber nur das Feld `unread` eines
//  Chats auf 0 zurücksetzen. Sonst kein Schreibzugriff.
//  n8n schreibt über das Firebase Admin SDK (Service-Account) und UMGEHT
//  diese Regeln vollständig – n8n ist davon also nicht betroffen.
//  Einspielen:  Firebase-Console -> Firestore -> Regeln  (oder `firebase deploy
//  --only firestore:rules`).
// ===========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Chats/Kontakte: lesen frei; Schreiben nur erlaubte Felder ----------
    //  Single-User, kein Login: Lesen ist ohnehin offen. Beim Schreiben
    //  begrenzen wir die Felder per allowlist, damit das Frontend NICHT
    //  versehentlich/böswillig n8n-Felder (lastText, status-Häkchen der
    //  Nachrichten, aiSummary …) überschreibt. unread bleibt auf 0 beschränkt.
    //  Teil 1: zusätzlich die Quantus-Verknüpfung (quantusContactId/OrgId).
    //  (Teil 2 erweitert die Liste um labels/pinned/manualUnread/status/
    //   followUpAt/notes.)
    match /wa_chats/{number} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['unread', 'quantusContactId', 'quantusOrgId'])
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['unread'])
                          || request.resource.data.unread == 0);
      allow create, delete: if false;
    }

    // --- Nachrichten: nur lesen (Schreiben ausschließlich n8n/Admin SDK) ----
    match /wa_messages/{msgId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Alles andere gesperrt ---------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
