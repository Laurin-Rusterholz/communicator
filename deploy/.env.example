# ===========================================================================
#  .env für den Evolution-Stack  (deploy/docker-compose.yml)
# ---------------------------------------------------------------------------
#  ▸ NUR EINE STELLE musst du anpassen: ersetze überall  1-2-3-4  durch deine
#    VPS-IP MIT BINDESTRICHEN  (z. B. aus 203.0.113.47  ->  203-0-113-47).
#  ▸ Den n8n-Containernamen (N8N_CONTAINER) nach  `docker ps`  eintragen.
#  ▸ Schlüssel/Passwörter sind bereits zufällig generiert – kannst du lassen.
#  ▸ Diese Datei enthält Secrets -> NICHT committen (steht in .gitignore).
# ===========================================================================

# --- PostgreSQL ---
POSTGRES_USER=evolution
POSTGRES_PASSWORD=8b3c1848a59ad257ee19e460ed2570c6
POSTGRES_DB=evolution

# --- Evolution API: globaler API-Key (für n8n + Manager-UI) ---
EVOLUTION_API_KEY=1da5027fb491d99a0e2f95139afe4cc522980fd00316df39

# --- Öffentliche HTTPS-Hostnamen via sslip.io ------------------------------
#  sslip.io löst <irgendwas>.<ip-mit-bindestrichen>.sslip.io auf die IP auf.
#  >>> 1-2-3-4 durch deine VPS-IP-mit-Bindestrichen ersetzen <<<
#  Beispiel VPS-IP 203.0.113.47:
#     N8N_HOSTNAME=n8n.203-0-113-47.sslip.io
#     EVO_HOSTNAME=evo.203-0-113-47.sslip.io
N8N_HOSTNAME=n8n.1-2-3-4.sslip.io
EVO_HOSTNAME=evo.1-2-3-4.sslip.io

# --- Name deines BESTEHENDEN n8n-Containers (aus `docker ps`) --------------
#  Häufige Werte: n8n  |  root-n8n-1  |  n8n-n8n-1
N8N_CONTAINER=n8n

# --- E-Mail für Let's-Encrypt-Benachrichtigungen ---------------------------
ACME_EMAIL=contact@laurin-rusterholz.ch
